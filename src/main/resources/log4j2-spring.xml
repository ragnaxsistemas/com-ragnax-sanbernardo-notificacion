<Configuration status="WARN">

    <Properties>
        <Property name="LOG_PATH">logs</Property>
    </Properties>

    <Appenders>

        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{HH:mm:ss} %-5level %logger - %msg%n"/>
        </Console>

        <RollingFile name="File"
                     fileName="${LOG_PATH}/app.log"
                     filePattern="${LOG_PATH}/%d{yyyy-MM}/app-%d{yyyy-MM-dd}.log">

            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} %-5level %logger - %msg%n"/>

            <Policies>
                <TimeBasedTriggeringPolicy interval="1"/>
            </Policies>

        </RollingFile>

    </Appenders>

    <Loggers>

        <Logger name="com.openhtmltopdf" level="off"/>

        <Root level="info">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="File"/>
        </Root>

    </Loggers>

</Configuration>